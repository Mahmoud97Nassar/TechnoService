# Copiez ce fichier vers .env et remplissez vos valeurs SMTP

PORT=3000

# Destinataire des demandes de support
SUPPORT_TO=votre-email@example.com

# Expéditeur affiché (optionnel)
SUPPORT_FROM="TechnoService" <noreply@example.com>

# SMTP (exemple Gmail : utilisez un mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-compte@gmail.com
SMTP_PASS=mot-de-passe-application
